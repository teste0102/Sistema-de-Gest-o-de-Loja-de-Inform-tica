# ===== APP =====
DEBUG=True
APP_NAME="Sistema Loja Informatica"
APP_VERSION="1.0.0"

# ===== DATABASE =====
# Docker Compose Configuration (recommended)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/loja_informatica

# Alternative: Individual settings
DB_TYPE=postgresql
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=loja_informatica

# ===== ACCESS DATABASES (para importação) =====
ACCESS_CADA=/caminho/CADA.MDB
ACCESS_OS=/caminho/OS.MDB
ACCESS_CAIXA=/caminho/CAIXA.MDB

# ===== FEATURES =====
ENABLE_OFFLINE_SYNC=True
SYNC_TIMEOUT_SECONDS=30
